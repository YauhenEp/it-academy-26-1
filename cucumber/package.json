{
  "name": "cucumber",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.26.1",
    "@wdio/cli": "^9.26.1",
    "@wdio/cucumber-framework": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1"
  },
  "scripts": {
    "wdio": "npm run clean && wdio run ./wdio.conf.js && npm run report",
    "clean": "npx rimraf -rf allure-results allure-report",
    "report": "allure generate allure-results --clean -o allure-report"
  },
  "dependencies": {
    "allure-commandline": "^2.38.1",
    "rimraf": "^6.1.3"
  }
}
